{
  "$schema": "https://oxc.rs/schemas/oxfmt-config.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": {
    "groups": [["builtin", "external"], "internal", ["parent", "sibling", "index"], "type"],
    "internalPattern": ["@/*"],
    "newlinesBetween": false
  },
  "sortTailwindcss": {
    "stylesheet": "./src/app/globals.css"
  },
  "ignorePatterns": ["node_modules", ".next", "dist", "build"]
}
